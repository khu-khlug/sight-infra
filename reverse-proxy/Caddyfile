api-v2.khlug.org {
	reverse_proxy {
		# Cloudflare 프록시를 신뢰하여 X-Forwarded-For 헤더를 그대로 전달하게됩니다.
		# 아래 줄을 컨테이너 시작 시 entrypoint.sh가 Cloudflare IP 대역으로 자동 교체합니다.(https://www.cloudflare.com/ips-v4/)
		# TRUSTED_PROXIES_CLOUDFLARE_IPS_V4
		dynamic srv {
			name spring-backend.sight.prod
			refresh 10s
		}
	}
}

www.khlug.org,
khlug.org,
before.khlug.org,
developers.khlug.org,
hello.khlug.org,
inventory.khlug.org,
inven.khlug.org,
library.khlug.org,
lib.khlug.org {
	@cors_preflight {
		method OPTIONS
		header Origin "https://app.khlug.org"
		header Access-Control-Request-Method *
	}

	handle @cors_preflight {
		header {
			Access-Control-Allow-Origin      "https://app.khlug.org"
			Access-Control-Allow-Methods     "GET, POST, PUT, PATCH, DELETE, OPTIONS"
			Access-Control-Allow-Headers     *
			Access-Control-Allow-Credentials "true"
		}
		respond "" 204
	}

	header {
		Access-Control-Allow-Credentials "true"
	}

	reverse_proxy {
		dynamic srv {
			name laravel-backend.sight.prod
			refresh 10s
		}
	}
}
